# Sculptor — Environment Variables
# Copy this file to .env.local and fill in your values.
# cp .env.local.example .env.local

# DeepSeek API (required for AI features, skip if using mock mode)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Mock mode: set to "true" to use mock AI responses (no API key needed)
NEXT_PUBLIC_MOCK_MODE=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Auth.js (next-auth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Email provider (optional — without SMTP magic links are logged to console)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@sculptor.app

# Ghost Text (Phase 1)
# Pause before ghost text triggers (ms)
NEXT_PUBLIC_GHOST_PAUSE_MS=800
# Max tokens for ghost text continuation
GHOST_MAX_TOKENS=150
